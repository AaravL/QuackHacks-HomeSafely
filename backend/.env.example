# Copy to .env and fill in values. Never commit .env.

# Auth (required for login/register)
JWT_SECRET=your-long-random-secret

# Gemini AI (optional – for recommendations; safety tips use Next.js env)
GEMINI_API_KEY=

# Snowflake (required for all DB operations: auth, posts, messages, users)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=

# Optional
# FRONTEND_URL=http://localhost:3000
# PORT=3001
